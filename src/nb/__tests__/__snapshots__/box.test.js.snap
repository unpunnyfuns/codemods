// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`box migration > adds View import when some elements are migrated and some are skipped 1`] = `
"import { Box } from 'native-base'

import { View, StyleSheet } from 'react-native';
import { space, color } from '@hb-frontend/nordlys';

export function Example() {
  return (
    <>
      <View style={styles.box0}>
        Successfully migrated
      </View>

      {/* TODO: Box requires manual migration
        Props that need manual handling:
          textAlign: "left" */
      }
      <Box textAlign="left" p="md">
        Skipped due to textAlign
      </Box>
    </>
  );
}

const styles = StyleSheet.create({
  box0: {
    padding: space.lg,
    backgroundColor: color.blue['500']
  }
});
"
`;

exports[`box migration > does not process local components that use Box in JSX 1`] = `
"import { HStack } from 'native-base';
import { FC } from 'react'

import { View, StyleSheet } from 'react-native';
import { space } from '@hb-frontend/nordlys';

type SectionProps = {
  testID?: string
  title: string
  value: string
}

// Local component that uses Box in its JSX - should NOT be processed
const Section: FC<SectionProps> = ({ testID, title, value }) => {
  return (
    <HStack mt="lg">
      <View style={styles.box0}>
        <Icon name="test" />
      </View>
      <HStack ml="sm" testID={testID}>
        <Text>{title}</Text>
        <Text>{value}</Text>
      </HStack>
    </HStack>
  );
}

export function Example() {
  return (
    <View style={styles.box1}>
      <Section testID="test-section" title="Title" value="Value" />
    </View>
  );
}

const styles = StyleSheet.create({
  box0: {
    marginTop: space['2xs']
  },

  box1: {
    padding: space.lg
  }
});
"
`;

exports[`box migration > migrates Box to View with StyleSheet styles 1`] = `
"import { View, StyleSheet } from 'react-native';
import { space, color, radius } from '@hb-frontend/nordlys';

export function MyComponent() {
  return (
    <>
      <View style={styles.box0}>
        Content 1
      </View>
      <View style={styles.box1}>
        Content 2
      </View>
      <View style={styles.box2}>
        Content 3
      </View>
    </>
  );
}

const styles = StyleSheet.create({
  box0: {
    width: "100%",
    padding: space.lg,
    backgroundColor: color.background.secondary,
    borderRadius: radius.md
  },

  box1: {
    marginBottom: space['2xl'],
    backgroundColor: color.white.HW1,
    flex: 1
  },

  box2: {
    backgroundColor: color.background.secondary,
    paddingHorizontal: space.sm,
    borderRadius: 16
  }
});
"
`;
